// ─── Sidebar.slint ────────────────────────────────────────────────────────────
// Contains BOTH the right pinned-apps bar AND the side panel (header + resize grip).
// Import this file in app.slint to get both components.

// ── Path-drawn control buttons ────────────────────────────────────────────────
component BackBtn inherits Rectangle {
    callback clicked();
    width: 28px;
    height: 28px;
    border-radius: 6px;
    background: t.has-hover ? #2a2a2a : transparent;
    animate background { duration: 80ms; }
    Path {
        x: 8px;
        y: 9px;
        width: 12px;
        height: 10px;
        stroke: t.has-hover ? #d4d4d4 : #6b7280;
        stroke-width: 1.5px;
        fill: transparent;
        commands: "M 10 0 L 2 5 L 10 10 M 2 5 L 12 5";
    }

    t := TouchArea {
        clicked => {
            root.clicked();
        }
    }
}

component RefreshBtn inherits Rectangle {
    callback clicked();
    width: 28px;
    height: 28px;
    border-radius: 6px;
    background: t.has-hover ? #2a2a2a : transparent;
    animate background { duration: 80ms; }
    Path {
        x: 7px;
        y: 7px;
        width: 14px;
        height: 14px;
        stroke: t.has-hover ? #d4d4d4 : #6b7280;
        stroke-width: 1.5px;
        fill: transparent;
        commands: "M 12 2 A 6 6 0 1 1 2 9 M 12 2 L 9 0 M 12 2 L 14 5";
    }

    t := TouchArea {
        clicked => {
            root.clicked();
        }
    }
}

component CloseBtn inherits Rectangle {
    callback clicked();
    width: 28px;
    height: 28px;
    border-radius: 6px;
    background: t.has-hover ? #3a1818 : transparent;
    animate background { duration: 80ms; }
    Path {
        x: 8px;
        y: 8px;
        width: 12px;
        height: 12px;
        stroke: t.has-hover ? #f87171 : #6b7280;
        stroke-width: 1.5px;
        fill: transparent;
        commands: "M 0 0 L 12 12 M 12 0 L 0 12";
    }

    t := TouchArea {
        clicked => {
            root.clicked();
        }
    }
}

component PinBtn inherits Rectangle {
    in-out property <string> lbl;
    in property <bool> active: false;
    in property <image> favicon;
    callback clicked();
    callback app-context-menu();
    width: 36px;
    height: 36px;
    border-radius: 8px;
    // Background and hover/active states
    background: t.has-hover ? #252525 : (active ? #1a3a5c : transparent);
    animate background { duration: 100ms; }
    
    // Icon container for better centering control
    HorizontalLayout {
        width: 100%; height: 100%;
        alignment: center;
        VerticalLayout {
            alignment: center;
            Rectangle {
                width: 22px; height: 22px;
                if root.favicon.width > 0: Image {
                    source: root.favicon;
                    width: 100%; height: 100%;
                    image-fit: contain;
                }
                if root.favicon.width == 0: Text {
                    text: root.lbl;
                    font-size: 13px;
                    color: root.active ? #4dabf7 : (t.has-hover ? #c8c8c8 : #6b7280);
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }
    }

    t := TouchArea {
        clicked => {
            root.clicked();
        }
        pointer-event(evt) => {
            if (evt.button == PointerEventButton.right && evt.kind == PointerEventKind.up) {
                root.app-context-menu();
            }
        }
    }
}

// ══════════════════════════════════════════════════════════════════════════════
//  SIDE PANEL — header + resize grip + webview slot
//  Place this inside HorizontalLayout with:  width: panel-w
// ══════════════════════════════════════════════════════════════════════════════
export component SidePanel inherits Rectangle {
    // State
    in property <string> panel-title: "Side Panel";
    in property <string> panel-domain: "";
    in property <image> panel-favicon;
    in property <bool> is-adding-app: false;
    in property <bool> is-resizing: false;

    // Actions
    callback on-back();
    callback on-refresh();
    callback on-close();
    callback on-copy-url(string);
    callback on-submit-add-app(string);
    callback on-add-current-tab();
    callback on-resize-start();
    callback on-resize-move(length);  // emits new panel width

    clip: true;

    // ── Header ──────────────────────────────────────────────────────────────
    Rectangle {
        x: 8px;
        y: 0px;                         // 8px inset for grip
        width: root.width - 8px;
        height: 44px;
        background: #1c1c1c;
        HorizontalLayout {
            padding-left: 10px;
            padding-right: 6px;
            spacing: 12px;
            
            // Centering helper: since we aren't using a Box, we manually offset the y
            // of the favicon and text so they align to the 44px vertical center.

            // ── Favicon ──────────────────────────────────────────────
            Rectangle {
                y: (44px - 24px) / 2;
                width: 24px;
                height: 24px;
                border-radius: 6px;
                background: #1e3a5c;
                clip: true;
                if root.panel-favicon.width == 0: Text {
                    text: root.panel-title != "" ? root.panel-title : "?";
                    color: #4dabf7;
                    font-size: 9px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    overflow: elide;
                }
                if root.panel-favicon.width > 0: Image {
                    source: root.panel-favicon;
                    width: 100%;
                    height: 100%;
                    image-fit: cover;
                }
            }

            // ── Title + domain ────────────────────────────────────────
            VerticalLayout {
                y: 0px;
                height: 44px;
                alignment: center;
                spacing: 1px;
                horizontal-stretch: 1;
                Text {
                    text: root.panel-title != "" ? root.panel-title : "Side Panel";
                    color: #e0e0e0;
                    font-size: 13px;
                    font-weight: 600;
                    overflow: elide;
                    vertical-alignment: center;
                }

                if root.panel-domain != "": Rectangle {
                    height: 14px; 
                    row_ta := TouchArea {
                        clicked => {
                            root.on-copy-url(root.panel-domain);
                        }
                    }

                    HorizontalLayout {
                        spacing: 4px;
                        
                        // Copy Button first
                        Rectangle {
                            width: 14px;
                            height: 14px;
                            border-radius: 3px;
                            opacity: row_ta.has-hover ? 1.0 : 0.0;
                            animate opacity { duration: 150ms; }
                            Path {
                                width: 10px;
                                height: 10px;
                                x: 2px;
                                y: 2px;
                                stroke: row_ta.pressed ? #ffffff : (row_ta.has-hover ? #d4d4d4 : #6b7280);
                                stroke-width: 1.2px;
                                fill: transparent;
                                commands: "M 3 3 L 8 3 L 8 8 L 3 8 Z M 2 6 L 1 6 L 1 1 L 6 1 L 6 2";
                            }
                        }

                        // URL Text
                        Text {
                            text: root.panel-domain;
                            color: row_ta.pressed ? #d4d4d4 : #6b7280;
                            font-size: 10px;
                            overflow: elide;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                        }
                    }
                }
            }

            // ── Buttons ──────────────────────────────────────────────
            HorizontalLayout {
                y: (44px - 28px) / 2;
                height: 28px;
                // No alignment needed here; the parent HorizontalLayout + spacer pins it to the right
                spacing: 2px;
                BackBtn {
                    clicked => {
                        root.on-back();
                    }
                }

                RefreshBtn {
                    clicked => {
                        root.on-refresh();
                    }
                }

                CloseBtn {
                    clicked => {
                        root.on-close();
                    }
                }
            }
        }

        // Bottom separator
        Rectangle {
            y: 43px;
            height: 1px;
            width: 100%;
            background: #2a2a2a;
        }
    }

    // ── Content Area ─────────────────────────────────────────────────────────
    Rectangle {
        y: 44px;
        width: parent.width;
        height: parent.height - 44px;
        background: root.is-adding-app ? #1c1c1c : #141414;
        
        if root.is-adding-app: VerticalLayout {
            padding: 24px;
            spacing: 16px;
            alignment: start;
            
            Text {
                text: "Add Sidebar App";
                font-size: 18px;
                color: #fff;
                font-weight: 600;
            }

            Rectangle {
                height: 36px;
                width: parent.width - 48px;
                border-radius: 6px;
                background: cur_ta.pressed ? #3b8ac4 : (cur_ta.has-hover ? #4dabf7 : #1e3a5c);
                animate background { duration: 100ms; }
                
                HorizontalLayout {
                    spacing: 8px;
                    padding: 8px;
                    alignment: center;
                    Path {
                        width: 16px;
                        height: 16px;
                        stroke: #fff;
                        stroke-width: 1.5px;
                        fill: transparent;
                        commands: "M 2 2 L 14 2 L 14 14 L 2 14 Z M 8 5 L 8 11 M 5 8 L 11 8";
                    }
                    Text {
                        text: "Add Current Tab";
                        color: #fff;
                        font-size: 13px;
                        font-weight: 600;
                        vertical-alignment: center;
                    }
                }
                
                cur_ta := TouchArea {
                    clicked => { root.on-add-current-tab(); }
                }
            }

            Text {
                text: "Or enter a custom URL:";
                font-size: 13px;
                color: #a0a0a0;
            }
            
            Rectangle {
                height: 36px;
                background: #2a2a2a;
                border-radius: 6px;
                border-width: 1px;
                border-color: url_input.has-focus ? #4dabf7 : #3a3a3a;
                
                url_input := TextInput {
                    x: 10px;
                    width: parent.width - 20px;
                    height: parent.height;
                    font-size: 13px;
                    color: #fff;
                    single-line: true;
                    vertical-alignment: center;
                    text: "https://";
                    accepted => { root.on-submit-add-app(self.text); }
                }
            }
            
            Rectangle {
                height: 32px;
                width: 80px;
                border-radius: 6px;
                background: submit_ta.pressed ? #3b8ac4 : (submit_ta.has-hover ? #4dabf7 : #1e3a5c);
                animate background { duration: 100ms; }
                
                Text {
                    text: "Add URL";
                    color: #fff;
                    font-size: 13px;
                    font-weight: 600;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
                
                submit_ta := TouchArea {
                    clicked => { root.on-submit-add-app(url_input.text); }
                }
            }
        }
        
        // ── Webview slot (native HWND fills this — tracked by Timer) ────────────
        if !root.is-adding-app: Rectangle {
            width: 100%;
            height: 100%;
        }
    }

    // ── Full-height resize grip (left 8px strip) ─────────────────────────────
    // Handles its own drag via absolute-position math — no overlay needed.
    grip-box := Rectangle {
        x: 0px;
        y: 0px;
        width: 8px;
        height: 100%;
        background: grip-t.has-hover || root.is-resizing ? #4dabf7 : #1e3050;
        animate background { duration: 100ms; }
        Text {
            text: "⋮";
            color: grip-t.has-hover || root.is-resizing ? #fff : #4dabf7;
            font-size: 9px;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        grip-t := TouchArea {
            mouse-cursor: ew-resize;
            pointer-event(evt) => {
                if (evt.kind == PointerEventKind.down) {
                    root.on-resize-start();
                }
                if (evt.kind == PointerEventKind.up) {
                    root.on-resize-start();
                } // signal up so parent resets is-resizing
            }
            moved => {
                if (root.is-resizing) {
                    root.on-resize-move(grip-box.absolute-position.x + self.mouse-x);
                }
            }
        }
    }
}

// ══════════════════════════════════════════════════════════════════════════════
//  SIDEBAR BAR — 44px right strip with search + pinned apps + pin-current
// ══════════════════════════════════════════════════════════════════════════════
export struct PinnedApp { title: string, url: string, icon: string, favicon: image}

export component SidebarBar inherits Rectangle {
    // State
    in property <[PinnedApp]> apps;
    in property <bool> sidebar-open: false;
    in property <string> active-url: "";
    in property <bool> is-appbar-mode: false;

    // Signals
    callback toggle-appbar-mode();
    callback minimize-window();
    callback close-window();
    callback search-toggled();
    callback app-toggled(string);   // url
    callback app-context-menu(string);
    callback add-app-menu();
    callback sidebar-settings();
    callback toggle-ai-chat();
    width: 44px;
    background: #1a1a1a;
    // Left border
    Rectangle {
        x: 0px;
        width: 1px;
        height: 100%;
        background: #2a2a2a;
    }

    VerticalLayout {
        padding: 6px;
        spacing: 4px;
        // alignment removed so Flickable can stretch

        // ── AI button ─────────────────────────────
        if root.is-appbar-mode: Rectangle {
            width: 36px;
            height: 36px;
            border-radius: 8px;
            background: ai_ta.has-hover ? #252525 : transparent;
            animate background { duration: 100ms; }
            Path {
                x: 7px;
                y: 7px;
                width: 22px;
                height: 22px;
                stroke: ai_ta.has-hover ? #e0e0e0 : #888;
                stroke-width: 1.5px;
                fill: transparent;
                commands: "M 2 2 L 12 2 L 12 10 L 8 10 L 5 13 L 5 10 L 2 10 Z M 5 5 L 5 6 M 9 5 L 9 6";
            }
            ai_ta := TouchArea { clicked => { root.toggle-ai-chat(); } }
        }

        // ── Search icon (magnifying glass path) ─────────────────────────────
        Rectangle {
            width: 36px;
            height: 36px;
            border-radius: 8px;
            background: srch.has-hover ? #252525 : (root.sidebar-open && root.active-url == "search" ? #1a3a5c : transparent);
            animate background { duration: 100ms; }
            Path {
                x: 9px;
                y: 9px;
                width: 18px;
                height: 18px;
                stroke: (root.sidebar-open && root.active-url == "search") ? #4dabf7 : (srch.has-hover ? #c8c8c8 : #6b7280);
                stroke-width: 1.5px;
                fill: transparent;
                commands: "M 10 10 m -4 0 a 4 4 0 1 0 8 0 a 4 4 0 1 0 -8 0 M 13 13 l 4 4";
            }

            srch := TouchArea {
                clicked => {
                    root.search-toggled();
                }
            }
        }

        Rectangle {
            height: 1px;
            width: 28px;
            background: #2a2a2a;
        }

        // ── Pinned apps ──────────────────────────────────────────────────────
        Flickable {
            vertical-stretch: 1;
            viewport-height: pinned-ly.preferred-height;
            viewport-width: 36px;
            
            pinned-ly := VerticalLayout {
                spacing: 4px;
                alignment: start;
                
                for app[i] in root.apps: PinBtn {
                    lbl: app.icon != "" ? app.icon : "W";
                    favicon: app.favicon;
                    active: root.sidebar-open && root.active-url == app.url;
                    clicked => {
                        root.app-toggled(app.url);
                    }
                    app-context-menu => {
                        root.app-context-menu(app.url);
                    }
                }
                
                Rectangle {
                    width: 36px;
                    height: 36px;
                    border-radius: 8px;
                    background: add_btn.has-hover ? #252525 : transparent;
                    animate background { duration: 100ms; }
                    Path {
                        x: 10px;
                        y: 10px;
                        width: 16px;
                        height: 16px;
                        stroke: add_btn.has-hover ? #c8c8c8 : #6b7280;
                        stroke-width: 1.5px;
                        commands: "M 8 0 L 8 16 M 0 8 L 16 8";
                    }
                    add_btn := TouchArea {
                        clicked => { root.add-app-menu(); }
                    }
                }
            }
        }
        Rectangle {
            height: 1px;
            width: 28px;
            background: #2a2a2a;
        }

        // ── Settings icon ──────────────────────────────
        Rectangle {
            width: 36px;
            height: 36px;
            border-radius: 8px;
            background: set_btn.has-hover ? #252525 : transparent;
            animate background { duration: 100ms; }
            Path {
                x: 8px;
                y: 8px;
                width: 20px;
                height: 20px;
                stroke: set_btn.has-hover ? #c8c8c8 : #6b7280;
                stroke-width: 1.5px;
                fill: transparent;
                commands: "M 10 7 A 3 3 0 1 1 7 10 M 10 2 L 10 4 M 10 18 L 10 16 M 2 10 L 4 10 M 18 10 L 16 10 M 4.3 4.3 L 5.7 5.7 M 15.7 15.7 L 14.3 14.3 M 15.7 4.3 L 14.3 5.7 M 4.3 15.7 L 5.7 14.3";
            }

            set_btn := TouchArea {
                clicked => {
                    root.sidebar-settings();
                }
            }
        }
    }
}
