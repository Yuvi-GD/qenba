// ─── SidePanel.slint ────────────────────────────────────────────────────────
// Side panel header with Path-drawn icons (no font/encoding issues) and
// a real favicon Image display when available.

// ── Path-drawn icon buttons ──────────────────────────────────────────────────
component BackArrow inherits Rectangle {
    callback clicked();
    width: 28px;
    height: 28px;
    border-radius: 6px;
    background: t.has-hover ? #2a2a2a : transparent;
    animate background { duration: 80ms; }
    // ← arrow path
    Path {
        x: 8px;
        y: 9px;
        width: 12px;
        height: 10px;
        stroke: t.has-hover ? #d4d4d4 : #6b7280;
        stroke-width: 1.5px;
        fill: transparent;
        commands: "M 10 0 L 2 5 L 10 10 M 2 5 L 12 5";
    }

    t := TouchArea {
        clicked => {
            root.clicked();
        }
    }
}

component RefreshIcon inherits Rectangle {
    callback clicked();
    width: 28px;
    height: 28px;
    border-radius: 6px;
    background: t.has-hover ? #2a2a2a : transparent;
    animate background { duration: 80ms; }
    // Circular refresh arc drawn with two Paths
    Path {
        x: 7px;
        y: 7px;
        width: 14px;
        height: 14px;
        stroke: t.has-hover ? #d4d4d4 : #6b7280;
        stroke-width: 1.5px;
        fill: transparent;
        // Three-quarter arc CW, then arrowhead
        commands: "M 12 2 A 6 6 0 1 1 2 9 M 12 2 L 9 0 M 12 2 L 14 5";
    }

    t := TouchArea {
        clicked => {
            root.clicked();
        }
    }
}

component CloseX inherits Rectangle {
    callback clicked();
    width: 28px;
    height: 28px;
    border-radius: 6px;
    background: t.has-hover ? #3a1818 : transparent;
    animate background { duration: 80ms; }
    Path {
        x: 8px;
        y: 8px;
        width: 12px;
        height: 12px;
        stroke: t.has-hover ? #f87171 : #6b7280;
        stroke-width: 1.5px;
        fill: transparent;
        commands: "M 0 0 L 12 12 M 12 0 L 0 12";
    }

    t := TouchArea {
        clicked => {
            root.clicked();
        }
    }
}

// ── Exported header component ──────────────────────────────────────────────
export component SidePanelHeader inherits Rectangle {
    in property <string> panel-title: "Side Panel";
    in property <string> panel-domain: "";
    in property <image> panel-favicon;            // real favicon if loaded
    callback on-back();
    callback on-refresh();
    callback on-close();
    height: 44px;
    background: #1c1c1c;
    clip: true;
    HorizontalLayout {
        padding-left: 10px;
        padding-right: 6px;
        spacing: 8px;

        // ── Favicon or letter badge ─────────────────────────────────
        Rectangle {
            width: 24px;
            y: 10px;
            height: 24px;
            border-radius: 6px;
            background: #1e3a5c;
            clip: true;

            // Letter fallback — shown when no favicon
            if root.panel-favicon.width == 0: Text {
                text: root.panel-title != "" ? root.panel-title : "P";
                // take first char via single-char trick: no substr in Slint, use full string
                // The displayed char is the full title but clipped to 1 char width visually
                color: #4dabf7;
                font-size: 12px;
                font-weight: 700;
                horizontal-alignment: center;
                vertical-alignment: center;
                overflow: clip;
            }

            // Real favicon image
            if root.panel-favicon.width > 0: Image {
                source: root.panel-favicon;
                width: 24px;
                height: 24px;
                image-fit: cover;
            }
        }

        // ── Title + domain stacked ──────────────────────────────────
        VerticalLayout {
            alignment: center;
            spacing: 2px;
            Text {
                text: root.panel-title != "" ? root.panel-title : "Side Panel";
                color: #e0e0e0;
                font-size: 12px;
                font-weight: 600;
                overflow: elide;
            }

            if root.panel-domain != "": Text {
                text: root.panel-domain;
                color: #4a4a5a;
                font-size: 10px;
                overflow: elide;
            }
        }

        // ── Path-drawn control buttons ──────────────────────────────
        HorizontalLayout {
            padding: 6px;
            spacing: 2px;
            visible: true;
            alignment: LayoutAlignment.end;
            BackArrow {
                clicked => {
                    root.on-back();
                }
            }

            RefreshIcon {
                clicked => {
                    root.on-refresh();
                }
            }

            CloseX {
                clicked => {
                    root.on-close();
                }
            }
        }
    }

    // Bottom separator
    Rectangle {
        y: 43px;
        height: 1px;
        width: 100%;
        background: #2a2a2a;
    }
}
