import { HorizontalBox, VerticalBox } from "std-widgets.slint";
import { SidePanel, SidebarBar, PinnedApp } from "Sidebar.slint";

export struct TabData {
    title: string,
    url: string,
    icon: string,
    favicon: image}

// ── Path-drawn nav buttons ─────────────────────────────────────────────────
component NavBack inherits Rectangle {
    in property <bool> on: true;
    callback clicked();
    width: 30px;
    height: 30px;
    border-radius: 6px;
    background: t.has-hover && on ? #2d2d2d : transparent;
    animate background { duration: 100ms; }
    Path {
        x: 9px;
        y: 10px;
        width: 12px;
        height: 10px;
        opacity: on ? 1.0 : 0.3;
        stroke: on ? (t.has-hover ? #e0e0e0 : #888) : #555;
        stroke-width: 1.5px;
        fill: transparent;
        commands: "M 10 0 L 2 5 L 10 10 M 2 5 L 12 5";
    }

    t := TouchArea {
        clicked => {
            if (on) {
                root.clicked();
            }
        }
    }
}

component NavFwd inherits Rectangle {
    in property <bool> on: true;
    callback clicked();
    width: 30px;
    height: 30px;
    border-radius: 6px;
    background: t.has-hover && on ? #2d2d2d : transparent;
    animate background { duration: 100ms; }
    Path {
        x: 9px;
        y: 10px;
        width: 12px;
        height: 10px;
        opacity: on ? 1.0 : 0.3;
        stroke: on ? (t.has-hover ? #e0e0e0 : #888) : #555;
        stroke-width: 1.5px;
        fill: transparent;
        commands: "M 2 0 L 10 5 L 2 10 M 10 5 L 0 5";
    }

    t := TouchArea {
        clicked => {
            if (on) {
                root.clicked();
            }
        }
    }
}

component NavReload inherits Rectangle {
    callback clicked();
    width: 30px;
    height: 30px;
    border-radius: 6px;
    background: t.has-hover ? #2d2d2d : transparent;
    animate background { duration: 100ms; }
    Path {
        x: 8px;
        y: 8px;
        width: 14px;
        height: 14px;
        stroke: t.has-hover ? #e0e0e0 : #888;
        stroke-width: 1.5px;
        fill: transparent;
        commands: "M 12 2 A 6 6 0 1 1 2 9 M 12 2 L 9 0 M 12 2 L 14 5";
    }

    t := TouchArea {
        clicked => {
            root.clicked();
        }
    }
}

component NavHome inherits Rectangle {
    callback clicked();
    width: 30px;
    height: 30px;
    border-radius: 6px;
    background: t.has-hover ? #2d2d2d : transparent;
    animate background { duration: 100ms; }
    Path {
        x: 7px;
        y: 5px;
        width: 16px;
        height: 16px;
        stroke: t.has-hover ? #e0e0e0 : #888;
        stroke-width: 1.5px;
        fill: transparent;
        commands: "M 0 8 L 8 0 L 16 8 M 3 8 L 3 16 L 13 16 L 13 8";
    }

    t := TouchArea {
        clicked => {
            root.clicked();
        }
    }
}

export component AppWindow inherits Window {
    title: root.initialized ? (root.tabs[root.active-tab].title != "" ? root.tabs[root.active-tab].title : "Qenba") : "QENBA_INIT_MODE";
    in-out property <bool> initialized: false;
    preferred-width: 1000px;
    preferred-height: 650px;
    no-frame: true;
    background: #141414;
    in-out property <[TabData]> tabs: [
        { title: "New Tab", url: "https://duckduckgo.com", icon: "D", favicon: @image-url("") }
    ];
    in-out property <int> active-tab: 0;
    in-out property <string> url: "https://duckduckgo.com";
    in-out property <bool> is-editing-url: false;
    out property <bool> addr-focused: root.is-editing-url;
    in-out property <bool> is-secure: true;
    in-out property <[PinnedApp]> pinned-apps: [];
    in-out property <bool> sidebar-open: false;
    in-out property <string> sidebar-title: "";
    in-out property <string> sidebar-url: "";
    in-out property <string> active-sidebar-url: "";
    in-out property <bool> sidebar-overlay: false;
    in-out property <image> sidebar-favicon;
    in-out property <length> sb-panel-w: 400px;
    in-out property <bool> is-resizing: false;
    in-out property <bool> is-adding-app: false;
    in-out property <bool> is-appbar-mode: false;

    // Callbacks provided by C++
    callback load-url(string);
    in-out property <bool> can-go-back: false;
    in-out property <bool> can-go-forward: false;
    in-out property <bool> show-home-button: true;
    in-out property <string> config-theme: "dark";
    callback close-window();
    callback minimize-window();
    callback maximize-window();
    callback window-move(length, length);
    callback window-resize(length, length);
    callback go-back();
    callback go-forward();
    callback go-home();
    callback show-profile();
    callback tab-clicked(int);
    callback new-tab();
    callback close-tab(int);
    callback sync-geometry(length, length, length, length);
    callback refresh();
    callback clear-addr-focus();
    callback sidebar-pin-current();
    callback sidebar-navigate(string);
    callback sidebar-remove-app(string);
    callback sidebar-back();
    callback sidebar-refresh();
    callback sidebar-close();
    callback sidebar-context-menu(string);
    callback copy-sidebar-url(string);
    callback sidebar-add-current-tab();
    callback sidebar-add-app-menu();
    callback notify-adding-app(bool);
    callback sidebar-settings();
    callback sidebar-submit-add-app(string);
    callback sidebar-hide();
    callback toggle-appbar-mode();

    // Timer logic in Slint for simple animations if needed
    callback toggle-ai-chat();
    callback app-toggled(string);
    callback sync-sidebar-geometry(length, length, length, length);
    dummy_focus := FocusScope {
        width: 0;
        height: 0;
    }

    clear-addr-focus => {
        root.is-editing-url = false;
        dummy_focus.focus();
    }
    
    // Logic for search panel toggle
    app-toggled(url) => {
        if (root.sidebar-open && root.active-sidebar-url == url) {
            root.sidebar-open = false;
            root.sidebar-hide();
            root.active-sidebar-url = "";
        } else {
            root.sidebar-open = true;
            root.active-sidebar-url = url;
            root.sidebar-navigate(url);
        }
    }
    property <length> area-x: webview-area.absolute-position.x;
    property <length> area-y: webview-area.absolute-position.y;
    property <length> area-w: webview-area.width - 2px;
    property <length> area-h: webview-area.height - 2px;
    property <bool> prev-appbar-open: false;
    property <bool> prev-is-appbar-mode: false;
    callback sync-appbar-width(length);
    Timer {
        interval: 16ms;
        running: true;
        triggered => {
            root.sync-geometry(root.area-x, root.area-y, root.area-w, root.area-h);
            
            // Sync AppBar width dynamically
            if (root.is-appbar-mode != root.prev-is-appbar-mode) {
                root.prev-is-appbar-mode = root.is-appbar-mode;
                if (root.is-appbar-mode) {
                    root.prev-appbar-open = root.sidebar-open;
                    root.sync-appbar-width(root.sidebar-open ? max(100px, root.sb-panel-w + 44px) : 44px);
                }
            } else if (root.is-appbar-mode) {
                if (root.sidebar-open != root.prev-appbar-open) {
                    root.prev-appbar-open = root.sidebar-open;
                    if (root.sidebar-open) {
                        root.sync-appbar-width(max(100px, root.sb-panel-w + 44px));
                    } else {
                        root.sync-appbar-width(44px);
                    }
                } else if (root.sidebar-open) {
                    root.sync-appbar-width(root.width);
                    root.sb-panel-w = max(56px, root.width - 44px);
                }
            }

            if (root.sidebar-open) {
                // In normal mode: Panel header=44px, titlebar=36px, navbar=44px → y=124px
                // In appbar mode: y=36px+44px=80px (Body is at y=36, header is 44px)
                // x starts 8px inside panel (past the grip), 0px body padding
                root.sync-sidebar-geometry(
                    root.is-appbar-mode ? 8px : root.area-x + root.area-w + 10px,
                    root.is-appbar-mode ? 80px : 124px,
                    root.is-appbar-mode ? root.width - 52px : root.sb-panel-w - 12px,
                    root.height - (root.is-appbar-mode ? 80px : 124px) - 2px
                );
            }
        }
    }

    // Fixed-position layout: avoids binding loops in frameless windows
    // TitleBar at y:0, NavBar at y:36, Body at y:80

    // ══ TITLE BAR   36px ══════════════════════════════════════════════════
    Rectangle {
        y: 0;
        height: 36px;
        width: root.width;
        background: #1a1a1a;
        TouchArea {
            width: 100%;
            height: 100%;
        }    // window drag handled by OS subclass
        
        HorizontalLayout {
            visible: !root.is-appbar-mode || root.sidebar-open;
            // Left side balanced to match the right side (176px) for perfect centering
            Rectangle {
                width: 176px;
                HorizontalLayout {
                    padding-left: 14px;
                    Text {
                        text: "Qenba";
                        font-weight: 700;
                        font-size: 12px;
                        color: #4dabf7;
                        letter-spacing: 0.5px;
                        vertical-alignment: center;
                    }
                }
            }

            // Centered Title Group (Segment 2)
            HorizontalLayout {
                horizontal-stretch: 1;
                alignment: center;
                visible: !root.is-appbar-mode;
                
                // Container for Title + Favicon
                HorizontalLayout {
                    padding: 0px;
                    spacing: 5px;
                    y: 10px;
                    alignment: LayoutAlignment.center;
                    max-height: 0px;
                    if root.tabs[root.active-tab].favicon.width >= 0: Image {
                        source: root.tabs[root.active-tab].favicon;
                        width: 16px;
                        z: 0;
                        height: 16px;
                        horizontal-alignment: ImageHorizontalAlignment.left;
                        vertical-alignment: ImageVerticalAlignment.top;
                        image-fit: ImageFit.contain;
                    }
                    Text {
                        text: root.tabs[root.active-tab].title != "" ? root.tabs[root.active-tab].title : "New Tab";
                        font-size: 13px;
                        color: #f0f0f0;
                        vertical-alignment: TextVerticalAlignment.top;
                        y: 0px;
                        z: 0;
                        horizontal-alignment: TextHorizontalAlignment.left;
                        overflow: elide;
                    }
                }
            }

            HorizontalLayout {
                width: root.is-appbar-mode ? 88px : 176px;
                height: 36px;
                alignment: end;
                
                // AppBar Mode Toggle
                Rectangle {
                    width: 44px;
                    height: 36px;
                    background: wtgl.has-hover ? #252525 : transparent;
                    animate background { duration: 80ms; }
                    Path {
                        x: 14px;
                        y: 10px;
                        width: 16px;
                        height: 16px;
                        stroke: wtgl.has-hover ? #ddd : #666;
                        stroke-width: 1.5px;
                        fill: transparent;
                        // Right double arrow or left double arrow
                        commands: root.is-appbar-mode ? "M 8 2 L 2 8 L 8 14 M 14 2 L 8 8 L 14 14" : "M 6 2 L 12 8 L 6 14 M 0 2 L 6 8 L 0 14";
                    }

                    wtgl := TouchArea {
                        clicked => {
                            root.toggle-appbar-mode();
                        }
                    }
                }

                if !root.is-appbar-mode: Rectangle {
                    width: 44px;
                    height: 36px;
                    background: wmin.has-hover ? #252525 : transparent;
                    animate background { duration: 80ms; }
                    Rectangle {
                        width: 10px;
                        height: 1px;
                        x: 17px;
                        y: 18px;
                        background: wmin.has-hover ? #ddd : #666;
                    }

                    wmin := TouchArea {
                        clicked => {
                            root.minimize-window();
                        }
                    }
                }

                if !root.is-appbar-mode: Rectangle {
                    width: 44px;
                    height: 36px;
                    background: wmax.has-hover ? #252525 : transparent;
                    animate background { duration: 80ms; }
                    Rectangle {
                        width: 10px;
                        height: 10px;
                        x: 17px;
                        y: 13px;
                        border-width: 1px;
                        border-color: wmax.has-hover ? #ddd : #666;
                        background: transparent;
                    }

                    wmax := TouchArea {
                        clicked => {
                            root.maximize-window();
                        }
                    }
                }

                Rectangle {
                    width: 44px;
                    height: 36px;
                    background: wcls.has-hover ? #c42b1c : transparent;
                    animate background { duration: 80ms; }
                    Path {
                        x: 17px;
                        y: 13px;
                        width: 10px;
                        height: 10px;
                        stroke: wcls.has-hover ? #fff : #666;
                        stroke-width: 1.1px;
                        commands: "M 0 0 L 10 10 M 10 0 L 0 10";
                    }

                    wcls := TouchArea {
                        clicked => {
                            root.close-window();
                        }
                    }
                }
            }
        }

        // Minimal Toggle Button when collapsed:
        if (root.is-appbar-mode && !root.sidebar-open): Rectangle {
            x: 0;
            width: 44px;
            height: 36px;
            background: wtgl_col.has-hover ? #252525 : transparent;
            animate background { duration: 80ms; }
            Path {
                x: 14px;
                y: 10px;
                width: 16px;
                height: 16px;
                stroke: wtgl_col.has-hover ? #ddd : #666;
                stroke-width: 1.5px;
                fill: transparent;
                // Double left arrow to exit AppBar mode
                commands: "M 10 2 L 4 8 L 10 14 M 16 2 L 10 8 L 16 14";
            }
            wtgl_col := TouchArea {
                clicked => { root.toggle-appbar-mode(); }
            }
        }
    }

    // ══ NAV BAR   44px ════════════════════════════════════════════════════
    Rectangle {
        visible: !root.is-appbar-mode;
        y: 36px;
        height: 44px;
        width: root.width;
        background: #1c1c1c;
        Rectangle {
            y: 43px;
            height: 1px;
            width: 100%;
            background: #272727;
        }

        HorizontalLayout {
            padding-left: 10px;
            padding-right: 10px;
            padding-top: 6px;
            padding-bottom: 6px;
            spacing: 4px;
            NavBack {
                on: root.can-go-back;
                clicked => {
                    root.go-back();
                }
            }

            NavFwd {
                on: root.can-go-forward;
                clicked => {
                    root.go-forward();
                }
            }

            NavReload {
                clicked => {
                    root.refresh();
                }
            }

            if root.show-home-button: NavHome {
                clicked => {
                    root.go-home();
                }
            }
            Rectangle {
                horizontal-stretch: 1;
                height: 30px;
                background: addr.has-focus ? #252525 : #1a1a1a;
                border-radius: 15px;
                border-width: 1px;
                border-color: addr.has-focus ? #4dabf7 : #333;
                animate background { duration: 100ms; }
                animate border-color { duration: 100ms; }
                HorizontalLayout {
                    padding-left: 14px;
                    padding-right: 14px;
                    spacing: 8px;
                    
                    // Status Icon (Lock for HTTPS, Alert for HTTP)
                    Rectangle {
                        width: 14px;
                        height: 14px;
                        y: (parent.height - self.height) / 2;
                        Path {
                            width: 100%;
                            height: 100%;
                            stroke: root.is-secure ? #888 : #ffaa00;
                            stroke-width: 1.5px;
                            fill: transparent;
                            commands: root.is-secure ? "M 3 6 L 3 4 A 4 4 0 0 1 11 4 L 11 6 M 2 6 L 12 6 L 12 13 L 2 13 Z" : "M 7 1 L 1 13 L 13 13 Z M 7 4 L 7 9 M 7 11 L 7 11.5";
                        }
                    }

                    Rectangle {
                        horizontal-stretch: 1;
                        addr := TextInput {
                            width: 100%;
                            height: 100%;
                            font-size: 13px;
                            color: #d4d4d4;
                            vertical-alignment: center;
                            single-line: true;
                            text <=> root.url;
                            edited => {
                                root.is-editing-url = true;
                            }
                            accepted => {
                                root.is-editing-url = false;
                                root.load-url(self.text);
                                dummy_focus.focus();
                            }
                        }
                    }

                    // Bookmark Star Icon
                    Rectangle {
                        width: 16px;
                        height: 16px;
                        y: (parent.height - self.height) / 2;
                        star_ta := TouchArea { }

                        Path {
                            width: 100%;
                            height: 100%;
                            stroke: star_ta.has-hover ? #e0e0e0 : #888;
                            stroke-width: 1.5px;
                            fill: transparent;
                            commands: "M 8 1 L 10 5 L 14 6 L 11 9 L 12 14 L 8 11 L 4 14 L 5 9 L 2 6 L 6 5 Z";
                        }
                    }
                }
            }

            // Download Icon
            Rectangle {
                width: 30px;
                height: 30px;
                border-radius: 6px;
                background: dl_ta.has-hover ? #2d2d2d : transparent;
                animate background { duration: 100ms; }
                Path {
                    x: 8px;
                    y: 8px;
                    width: 14px;
                    height: 14px;
                    stroke: dl_ta.has-hover ? #e0e0e0 : #888;
                    stroke-width: 1.5px;
                    fill: transparent;
                    commands: "M 7 1 L 7 10 M 4 7 L 7 10 L 10 7 M 2 13 L 12 13";
                }

                dl_ta := TouchArea { }
            }

            // AI Chat Icon
            Rectangle {
                width: 30px;
                height: 30px;
                border-radius: 6px;
                background: ai_ta.has-hover ? #2d2d2d : transparent;
                animate background { duration: 100ms; }
                Path {
                    x: 4px;
                    y: 4px;
                    width: 22px;
                    height: 22px;
                    stroke: ai_ta.has-hover ? #e0e0e0 : #888;
                    stroke-width: 1.5px;
                    fill: transparent;
                    commands: "M 2 2 L 12 2 L 12 10 L 8 10 L 5 13 L 5 10 L 2 10 Z M 5 5 L 5 6 M 9 5 L 9 6";
                }

                ai_ta := TouchArea {
                    clicked => {
                        root.toggle-ai-chat();
                    }
                }
            }
        }
    }

    // ══ BODY ═════════════════════════════════════════════════════════════
    Rectangle {
        y: root.is-appbar-mode ? 36px : 80px;
        width: root.width;
        height: root.is-appbar-mode ? max(0px, root.height - 36px) : max(0px, root.height - 80px);
        background: #141414;
        HorizontalLayout {
            padding-left: root.is-appbar-mode ? 0px : 2px;
            padding-right: root.is-appbar-mode ? 0px : 5px;
            padding-bottom: root.is-appbar-mode ? 0px : 2px;
            spacing: 0px;

            // ── Left tab bar  42→180px animated ──────────────────────────
            tab-bar := Rectangle {
                visible: !root.is-appbar-mode;
                width: root.is-appbar-mode ? 0px : (tab-touch.has-hover ? 180px : 42px);
                height: 100%;
                background: #1a1a1a;
                clip: true;
                animate width {
                    duration: 150ms;
                    easing: ease-out;
                }
                Rectangle {
                    x: tab-bar.width - 1px;
                    width: 1px;
                    height: 100%;
                    background: #272727;
                }

                tab-touch := TouchArea {
                    width: 100%;
                    height: 100%;
                    VerticalLayout {
                        padding-top: 5px;
                        padding-bottom: 5px;
                        spacing: 3px;
                        alignment: start;
                        for tab[i] in root.tabs: Rectangle {
                            height: 36px;
                            clip: true;
                            background: root.active-tab == i ? #1a3a5c : (tb.has-hover ? #222 : transparent);
                            animate background { duration: 100ms; }
                            tb := TouchArea {
                                clicked => {
                                    root.tab-clicked(i);
                                }
                            }

                            // Icon area — explicitly 42px wide to anchor the collapsed state
                            Rectangle {
                                x: 0px;
                                width: 42px;
                                height: 36px;
                                
                                // Centered Icon Circle (Relative to the 42px container)
                                Rectangle {
                                    x: (parent.width - self.width) / 2;
                                    y: (parent.height - self.height) / 2;
                                    width: 24px;
                                    height: 22px;
                                    border-radius: 6px;
                                    background: root.active-tab == i ? #4dabf7 : #252525;
                                    clip: true;
                                    if tab.favicon.width > 0: Image {
                                        source: tab.favicon;
                                        width: 100%;
                                        height: 100%;
                                        image-fit: contain;
                                    }
                                    if tab.favicon.width == 0: Text {
                                        text: tab.icon != "" ? tab.icon : "B";
                                        color: root.active-tab == i ? #0d1b2a : #6b7280;
                                        font-size: 11px;
                                        font-weight: 700;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                            // Title — starts at x=40px, clipped by parent
                            if tab-bar.width > 100px: Text {
                                x: 40px;
                                y: 0px;
                                width: tab-bar.width - 66px;
                                height: 36px;
                                text: tab.title != "" ? tab.title : "New Tab";
                                color: root.active-tab == i ? #e0e0e0 : #888;
                                font-size: 11px;
                                vertical-alignment: center;
                                overflow: elide;
                            }
                            // Close btn
                            if tab-bar.width > 150px && root.tabs.length > 1: Rectangle {
                                x: tab-bar.width - 28px;
                                y: 9px;
                                width: 18px;
                                height: 18px;
                                border-radius: 5px;
                                background: cx.has-hover ? #3a1818 : transparent;
                                cx := TouchArea {
                                    clicked => {
                                        root.close-tab(i);
                                    }
                                }

                                Path {
                                    x: 3px;
                                    y: 3px;
                                    width: 12px;
                                    height: 12px;
                                    stroke: cx.has-hover ? #f87171 : #555;
                                    stroke-width: 1.3px;
                                    fill: transparent;
                                    commands: "M 0 0 L 12 12 M 12 0 L 0 12";
                                }
                            }
                        }

                        // New tab
                        Rectangle {
                            height: 36px;
                            border-radius: 8px;
                            clip: true;
                            background: nbt.has-hover ? #222 : transparent;
                            animate background { duration: 100ms; }
                            nbt := TouchArea {
                                clicked => {
                                    root.new-tab();
                                }
                            }

                            // Centered Icon Circle
                            Rectangle {
                                x: (42px - self.width) / 2;
                                y: (36px - self.height) / 2;
                                width: 24px;
                                height: 22px;
                                border-radius: 6px;
                                background: nbt.has-hover ? #333 : #1e1e1e;
                                Text {
                                    text: "+";
                                    color: #4dabf7;
                                    font-size: 16px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }

                            if tab-bar.width > 100px: Text {
                                x: 40px;
                                y: 0px;
                                height: 36px;
                                text: "New Tab";
                                color: #4dabf7;
                                font-size: 11px;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }

            // ── Main webview slot ──────────────────────────────────────
            webview-area := Rectangle {
                visible: !root.is-appbar-mode;
                horizontal-stretch: root.is-appbar-mode ? 0 : 1;
                max-width: root.is-appbar-mode ? 0px : 100000px;
                background: #141414;
            }

            // ── Side panel (from Sidebar.slint) ───────────────────────
            if root.sidebar-open: SidePanel {
                width: root.is-appbar-mode ? root.width - 44px : root.sb-panel-w;
                panel-title: root.sidebar-title;
                panel-domain: root.sidebar-url;
                panel-favicon: root.sidebar-favicon;
                is-resizing: root.is-resizing;
                is-adding-app: root.is-adding-app;
                on-back => {
                    root.sidebar-back();
                }
                on-refresh => {
                    root.sidebar-refresh();
                }
                on-close => {
                    if (root.is-adding-app) {
                        root.is-adding-app = false;
                        root.notify-adding-app(false);
                    }
                    root.sidebar-close();
                    root.active-sidebar-url = "";
                }
                on-copy-url(url) => {
                    root.copy-sidebar-url(url);
                }
                on-add-current-tab => {
                    root.sidebar-add-current-tab();
                }
                on-submit-add-app(url) => {
                    root.sidebar-submit-add-app(url);
                }
                // resize-start: down sets is-resizing=true, up sets it false
                on-resize-start => {
                    root.is-resizing = !root.is-resizing;
                }
                on-resize-move(abs-x) => {
                    // abs-x = absolute window x of the mouse
                    // panel_w = window_w - right_bar(44) - abs_x
                    root.sb-panel-w = max(180px, min(root.width * 0.55,
                        root.width - 44px - abs-x));
                }
            }

            // ── Right sidebar bar (from Sidebar.slint) ────────────────
            SidebarBar {
                apps: root.pinned-apps;
                sidebar-open: root.sidebar-open || root.is-appbar-mode;
                active-url: root.active-sidebar-url;
                is-appbar-mode: root.is-appbar-mode;
                minimize-window => { root.minimize-window(); }
                close-window => { root.close-window(); }
                toggle-appbar-mode => {
                    root.toggle-appbar-mode();
                }
                search-toggled => {
                    if (root.sidebar-open && root.active-sidebar-url == "search") {
                        root.sidebar-close();
                        root.active-sidebar-url = "";
                    } else {
                        root.sidebar-url = "duckduckgo.com";
                        root.active-sidebar-url = "search";
                        root.sidebar-navigate("https://duckduckgo.com");
                    }
                }
                // Connect the new exposed callback
                app-toggled(url) => {
                    root.app-toggled(url);
                }
                app-context-menu(url) => {
                    root.sidebar-context-menu(url);
                }
                add-app-menu => {
                    root.sidebar-add-app-menu();
                }
                sidebar-settings => {
                    root.sidebar-settings();
                }
                toggle-ai-chat => {
                    root.toggle-ai-chat();
                }
            }
        }
    }
}
