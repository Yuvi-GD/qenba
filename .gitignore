# ==============================================================================
# Qenba Browser .gitignore
# ==============================================================================

# --- CMake / Build Outputs ---
/build/
/out/
/bin/
/lib/
CMakeCache.txt
CMakeFiles/
CMakeSettings.json
CMakePresets.json
/CMakePresets.json
CTestTestfile.cmake
Makefile
cmake_install.cmake
install_manifest.txt
compile_commands.json
.cmake/

# --- MSVC / Visual Studio Artifacts ---
.vs/
*.sln
*.vcxproj
*.vcxproj.filters
*.vcxproj.user
*.suo
*.user
*.ncb
*.sdf
*.opensdf
*.vcproj
*.filters
*.ipch
*.aps
*.db
*.opendb
*.VC.db
*.VC.opendb

# --- Compiler / Linker Intermediate & Output Files ---
*.obj
*.o
*.gch
*.pch
*.lib
*.a
*.pdb
*.idb
*.ilk
*.exp
*.exe
*.dll
*.so
*.dylib
*.exp
*.map

# --- Third-party Dependencies ---
# Ignore downloaded Slint binaries, but keep the directory structure
third_party/slint/*
!third_party/slint/.gitkeep


# --- Qenba Runtime Configurations & Cache ---
# The runtime config.json contains personal preferences/states.
/config/config.json
# Favicon download cache folder (custom protocol cache)
/favicon_cache/
*.log
build_log.txt
err.txt
out.txt

# --- VS Code Configurations ---
.vscode/
# Keep standard task/launch profiles if desired, but general .vscode/ is ignored.

# --- OS Caches & Metadata ---
.DS_Store
Thumbs.db
desktop.ini

# --- Third-party Installer Junk ---
# Ignore temporary plugins directory generated during Slint extraction/installation
third_party/slint/\$PLUGINSDIR/
third_party/slint/$PLUGINSDIR/
**/$PLUGINSDIR/
**/$PLUGINSDIR/**
